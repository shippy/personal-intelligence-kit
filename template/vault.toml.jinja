# vault.toml — Runtime configuration for {{ vault_name }}
# Generated by copier. Edit freely after generation.
# Skills read this file to discover enabled sources and paths.

[vault]
name = "{{ vault_name }}"
owner = "{{ owner_name }}"

[notes]
app = "{{ notes_app }}"
{%- if notes_app != 'none' %}
vault_path = "{{ notes_vault_path }}"
drafts_path = "{{ drafts_path }}"
{%- endif %}

[sources]

{%- if enable_email %}

[sources.email]
enabled = true
path = "{{ email_path }}"
provider = "notmuch"  # mbsync + notmuch
{%- endif %}

{%- if enable_browser %}

[sources.browser]
enabled = true
type = "{{ browser_type }}"
{%- endif %}

{%- if enable_journal %}

[sources.journal]
enabled = true
type = "{{ journal_type }}"
path = "{{ journal_path }}"
{%- endif %}

{%- if enable_tasks %}

[sources.tasks]
enabled = true
provider = "{{ task_provider }}"
db_path = "{{ task_db_path }}"
{%- endif %}

{%- if enable_git %}

[sources.git]
enabled = true
# Each scope maps a parent directory to the author email(s) to track there.
# Add more [[sources.git.scopes]] sections as needed.
#
# [[sources.git.scopes]]
# path = "~/Documents"
# authors = ["you@example.com"]
#
# [[sources.git.scopes]]
# path = "~/Work"
# authors = ["you@company.com"]
{%- endif %}

[output]
root = "output"
reports = "output/reports"
alerts = "output/alerts"
reflections = "output/reflections"
briefings = "output/briefings"
drafts_for_review = "output/drafts-for-review"

[logs]
root = "logs"
activity = "logs/activity.md"
errors = "logs/errors.md"
