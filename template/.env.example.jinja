# {{ vault_name }} — Environment variables
# Copy this file to `.env` and fill in values.

# ---- LLM API ----
# Required by: weekly-reflection (pydantic-ai synthesis), stale-drafts (LLM ranking)
# Without this key, those skills degrade gracefully (heuristic mode only).
# You can use either name — CLAUDE_API_KEY avoids conflict with Claude Code's own env.
ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=

{% if enable_email -%}
# ---- Email (mbsync + notmuch) ----
# No secrets needed here — mbsync reads ~/.mbsyncrc.
# See docs/SETUP-email.md for credential setup (app password + keychain).
{% endif %}
{% if enable_tasks and task_provider == 'microsoft-todo' -%}
# ---- Microsoft To-Do (Graph API) ----
# Uses Azure CLI auth: run `az login` before sync.
# Alternatively, set these for app-registration auth:
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
{% endif %}
{% if enable_tasks and task_provider == 'todoist' -%}
# ---- Todoist ----
TODOIST_API_TOKEN=
{% endif %}
{% if enable_contacts_mcp -%}
# ---- Clay.earth contacts (MCP) ----
CLAY_API_KEY=
{% endif %}
