<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude.daily-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/uv</string>
        <string>run</string>
        <string>--env-file</string>
        <string>{{ vault_path }}/.env</string>
        <string>{{ vault_path }}/.claude/skills/data-sync/sync_all.py</string>
        <string>--yes</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>20</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>{{ vault_path }}</string>

    <key>StandardOutPath</key>
    <string>{{ vault_path }}/logs/sync-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>{{ vault_path }}/logs/sync-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>LowPriorityIO</key>
    <true/>
</dict>
</plist>
